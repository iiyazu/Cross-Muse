# Backend entrypoints read exported variables; they do not automatically load .env.

# Runtime root. Defaults to ./xmuse.
# XMUSE_ROOT=./xmuse

# Optional default model override. Participant roster/session profiles remain authoritative.
# XMUSE_CODEX_MODEL=gpt-5.4

# Fixed local Chat API coordinate used by managed probes and server-side Next proxies.
# XMUSE_CHAT_API_URL=http://127.0.0.1:8201
# XMUSE_CHAT_API_BASE_URL=http://127.0.0.1:8201/api/chat

# Server-only credential for managed Room writes and operator actions. The Workroom launcher
# generates one automatically. Never use a NEXT_PUBLIC_* name.
# XMUSE_OPERATOR_TOKEN=change-me

# Optional additional local browser origins.
# XMUSE_FRONTEND_URL=http://localhost:3000
# XMUSE_FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
