# xmuse — Environment Configuration
#
# Copy this file to .env and adjust values for your environment.
# Provider secrets are optional for default CI and only required for the
# provider path that uses them. All other vars have safe defaults.
#
# Production groupchat env bundle (uncomment to use):
# XMUSE_PEER_GOD_BACKEND=ray
# XMUSE_EXECUTE_GOD_BACKEND=ray
# XMUSE_REVIEW_GOD_BACKEND=ray
# XMUSE_RAY_GOD_TRANSPORT=app-server
# XMUSE_RAY_GOD_MCP=1
# XMUSE_RAY_GOD_EFFORT=low
# XMUSE_CHAT_API_URL=http://127.0.0.1:8201

# ── Provider Secrets (not required for default CI) ───────────────────────────

# DEEPSEEK_API_KEY — OpenCode provider key; only needed if using OpenCode
# worker path. Missing key causes CONFIG_ERROR health check and UNAVAILABLE
# adapter status.
# DEEPSEEK_API_KEY=

# XMUSE_ROOT — Path to xmuse runtime root. Defaults to ./xmuse if unset.
# XMUSE_ROOT=./xmuse

# ── Runtime Backend (production groupchat) ───────────────────────────────────

# XMUSE_PEER_GOD_BACKEND — Backend for peer GOD sessions. Default: "ray"
# XMUSE_PEER_GOD_BACKEND=ray

# XMUSE_EXECUTE_GOD_BACKEND — Backend for execution GOD sessions. Default: "ray"
# XMUSE_EXECUTE_GOD_BACKEND=ray

# XMUSE_REVIEW_GOD_BACKEND — Backend for review GOD sessions. Default: "ray"
# XMUSE_REVIEW_GOD_BACKEND=ray

# XMUSE_RAY_GOD_TRANSPORT — Ray GOD transport mode. Default: "app-server"
# XMUSE_RAY_GOD_TRANSPORT=app-server

# XMUSE_RAY_GOD_EFFORT — Ray GOD effort level. Options: none, minimal, low,
# medium, high, xhigh. Default: "low"
# XMUSE_RAY_GOD_EFFORT=low

# XMUSE_RAY_GOD_MCP — Enable MCP writeback for Ray GOD sessions.
# Set to 1 to enable (off by default to prevent accidental MCP exposure in
# regular Ray sessions). Default: "0"
# XMUSE_RAY_GOD_MCP=0

# XMUSE_DEGRADED_LOCAL_GOD_MODE — Enable degraded local GOD mode (no Ray).
# Default: disabled
# XMUSE_DEGRADED_LOCAL_GOD_MODE=

# XMUSE_RUNTIME_BACKEND — Runtime backend type for read envelopes.
# Default: "ray"
# XMUSE_RUNTIME_BACKEND=ray

# ── Provider / Model ─────────────────────────────────────────────────────────

# XMUSE_CODEX_MODEL — Model identifier used for Codex agent interactions.
# Default: "gpt-5.4"
# XMUSE_CODEX_MODEL=gpt-5.4

# DEEPSEEK_MODEL — Model name for the DeepSeek provider. OpenCode variant is
# fixed separately as --variant max.
# Default: "deepseek-v4-flash"
# DEEPSEEK_MODEL=deepseek-v4-flash

# DEEPSEEK_BASE_URL — Optional base URL override for the DeepSeek API.
# Leave unset to use the provider's default endpoint.
# DEEPSEEK_BASE_URL=

# ── Orchestrator ─────────────────────────────────────────────────────────────

# XMUSE_RECONCILE_GATE_REVIEW_CONCURRENCY — Max concurrent review gate runs.
# Default: unlimited (invalid values fall back to 16).
# XMUSE_RECONCILE_GATE_REVIEW_CONCURRENCY=

# XMUSE_RECOVERY — Serialized RecoveryConfig for crash recovery behaviour.
# If unset, uses RecoveryConfig defaults.
# XMUSE_RECOVERY=

# ── TUI / Dashboard ──────────────────────────────────────────────────────────

# XMUSE_CHAT_API_URL — URL of the Chat API for the TUI to connect to.
# Default: "http://127.0.0.1:8201"
# XMUSE_CHAT_API_URL=http://127.0.0.1:8201

# XMUSE_SUPERPOWERS — Set to 1 to enable superpowers skill bridge.
# Default: disabled
# XMUSE_SUPERPOWERS=0

# ── Legacy (not current mainline) ────────────────────────────────────────────
#
# These variables configure the old master_loop, hermes_reporter, and shell
# scripts. The current groupchat mainline does not depend on them.

# XMUSE_REVIEW_GATE — Enable review gate in master_loop. Default: "1"
# XMUSE_REVIEW_GATE=1

# XMUSE_REVIEW_CODEX_CMD — Codex command used for reviews. Default: "codex"
# XMUSE_REVIEW_CODEX_CMD=codex

# XMUSE_REVIEW_MODEL — Model used for reviews in master_loop. Default: "gpt-5.5"
# XMUSE_REVIEW_MODEL=gpt-5.5

# XMUSE_REVIEW_TIMEOUT_S — Review timeout in seconds. Default: "300"
# XMUSE_REVIEW_TIMEOUT_S=300

# XMUSE_LOOP_ROOT — Root directory for hermes_reporter. Default: parent
# directory of the hermes_reporter.py script.
# XMUSE_LOOP_ROOT=

# XMUSE_REPORT_ONLY — Set to "1" for report-only mode (skip execution).
# Default: "" (full mode)
# XMUSE_REPORT_ONLY=

# XMUSE_MAX_HOURS — Max run hours for overnight_runner.sh. Default: "10"
# XMUSE_MAX_HOURS=10

# XMUSE_MONITOR_INTERVAL_SECONDS — Poll interval for scheduler_monitor.sh.
# Default: "600"
# XMUSE_MONITOR_INTERVAL_SECONDS=600

# XMUSE_MONITOR_LOG_FILE — Log file path for scheduler_monitor.sh.
# Default: "/tmp/xmuse_scheduler_monitor.log"
# XMUSE_MONITOR_LOG_FILE=/tmp/xmuse_scheduler_monitor.log

# XMUSE_MONITOR_PID_FILE — PID file path for scheduler_monitor.sh.
# Default: "/tmp/xmuse_scheduler_monitor.pid"
# XMUSE_MONITOR_PID_FILE=/tmp/xmuse_scheduler_monitor.pid

# XMUSE_MONITOR_LOCK_FILE — Lock file path for scheduler_monitor.sh.
# Default: "/tmp/xmuse_scheduler_monitor.lock"
# XMUSE_MONITOR_LOCK_FILE=/tmp/xmuse_scheduler_monitor.lock
