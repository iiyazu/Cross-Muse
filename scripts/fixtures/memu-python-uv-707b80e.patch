+    def test_grouped_and_repeated_citations_keep_stable_numbers(self):
+        """Should reuse one number per item across grouped and repeated references."""
+        text = "Drinks [ref:tea,coffee]. More tea [ref:tea]."
+
+        result = format_references_as_citations(text)
+
+        assert result == "Drinks [1,2]. More tea [1].\n\nReferences:\n[1] tea\n[2] coffee"
